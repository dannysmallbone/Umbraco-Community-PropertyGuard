{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  },
  "ConnectionStrings": {
    "umbracoDbDSN": "Data Source=|DataDirectory|/Umbraco.sqlite.db;Cache=Shared;Foreign Keys=True;Pooling=True",
    "umbracoDbDSN_ProviderName": "Microsoft.Data.Sqlite"
  },
  "Umbraco": {
    "CMS": {
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "Danny Smallbone",
        "UnattendedUserEmail": "dannysmallbone@gmail.com",
        "UnattendedUserPassword": "password321",
        "UnattendedTelemetryLevel": "Detailed"
      },
      "Content": {
        "MacroErrors": "Throw"
      },
      "Hosting": {
        "Debug": true
      },
      "Global": {
        "TimeOut": "1.00:00:00"
      }
    }
  },
  "PropertyGuard": {
    "Definitions": [
      {
        "ContentTypeAlias": "home",
        "PropertyAlias": "HeroCtalink",
        "Message": "Property protected by config Property Guard"
      }
    ]
  }
}
